# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-measurement-id-here

# Formly Email Service
# Configure your server-side form ID from https://formly.email/dashboard
FORMLY_FORM_ID=your-form-id-here

# GitHub API (for blog posts)
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_OWNER=raniellimontagna
GITHUB_REPO=ranimontagna-blog-content

# GitHub Webhook Secret (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=your-webhook-secret-here

# Google Gemini API (for AI chat persona — primary provider)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter API (fallback provider when Gemini is unavailable)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL_PRIMARY=google/gemma-3-4b-it:free
OPENROUTER_MODEL_FALLBACK=openrouter/auto

# Groq API (additional fallback provider when Gemini/OpenRouter are unavailable)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# Chat providers timeout in milliseconds (applies per provider request)
CHAT_PROVIDER_TIMEOUT_MS=12000

# Upstash Redis REST (recommended for persistent chat rate limiting in production)
UPSTASH_REDIS_REST_URL=https://your-upstash-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here
CHAT_RATE_LIMIT_PREFIX=chat:rate-limit
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=600000

# Sentry DSN
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
