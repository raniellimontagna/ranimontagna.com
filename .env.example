# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-measurement-id-here

# Formly Email Service
# Configure your server-side form ID from https://formly.email/dashboard
FORMLY_FORM_ID=your-form-id-here

# GitHub API (for blog posts)
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_OWNER=raniellimontagna
GITHUB_REPO=ranimontagna-blog-content

# Public blog media base URL (Cloudflare R2 custom domain or r2.dev test URL)
# Relative coverImage and MDX img paths resolve against this URL when configured.
NEXT_PUBLIC_BLOG_MEDIA_URL=https://media.ranimontagna.com

# GitHub Webhook Secret (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=your-webhook-secret-here

# DeepSeek API (primary provider)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# Optional fallback providers (disabled unless the matching flag is true)
# Enable a fallback only after its live evaluation corpus passes.
CHAT_ENABLE_GEMINI_FALLBACK=false
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

CHAT_ENABLE_OPENROUTER_FALLBACK=false
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL_PRIMARY=google/gemma-3-4b-it:free

CHAT_ENABLE_GROQ_FALLBACK=false
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# One total deadline shared by the complete provider chain (integer, 1-60000 ms)
CHAT_TOTAL_DEADLINE_MS=12000

# Upstash Redis REST (recommended for persistent chat rate limiting in production)
UPSTASH_REDIS_REST_URL=https://your-upstash-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here
CHAT_RATE_LIMIT_PREFIX=chat:rate-limit
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=600000

# Sentry DSN
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
